#!/bin/bash
# dotfiles_uninstall — remove everything installed by dotfiles_install
# Interactive: prompts before each removal step.
# Does NOT remove Homebrew.
#
# Usage: dotfiles_uninstall [--keep-repos]
#   --keep-repos   Skip removal of per-account repository folders.
#                  Useful when resetting between test runs.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
REPO_ROOT="$(cd "$(dirname "$_self")" && pwd -P)"
SCRIPTS_ROOT="${REPO_ROOT}/scripts"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

# ─── args ─────────────────────────────────────────────────────────────────────

KEEP_REPOS=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --keep-repos) KEEP_REPOS=true; shift ;;
        -h|--help)
            echo "Usage: dotfiles_uninstall [--keep-repos]"
            echo ""
            echo "  --keep-repos   Skip removal of per-account repository folders."
            echo "                 Useful when resetting between test runs."
            exit 0
            ;;
        *) dotfiles_usage_error "Unknown option: $1" "dotfiles_uninstall [--keep-repos]" ;;
    esac
done

# ─── helpers ──────────────────────────────────────────────────────────────────

confirm() {
    local msg="$1"
    dotfiles_ui_prompt "${msg} (y/N)"
    local ans
    read -r ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

section() { dotfiles_ui_section_warn "$1"; }

brew_uninstall() {
    local pkg="$1" flag="${2:-}"
    if command -v brew &>/dev/null; then
        if brew list ${flag} "$pkg" &>/dev/null 2>&1; then
            dotfiles_ui_info "Uninstalling $pkg..."
            brew uninstall ${flag} "$pkg" && dotfiles_ui_success "  $pkg removed" || dotfiles_ui_info "  Could not remove $pkg"
        else
            dotfiles_ui_info "  $pkg not installed via Homebrew, skipping"
        fi
    fi
}

# ─── 1. Check for unpushed git changes ────────────────────────────────────────

section "Check for unpushed git changes"

if [ -d "${DOTFILES_GITHUB_ROOT}" ]; then
    DIRTY_REPOS=()
    while IFS= read -r git_dir; do
        [ -z "$git_dir" ] && continue
        repo_root="$(dirname "$git_dir")"
        # Skip the dotfiles repo itself
        [ "$repo_root" = "$REPO_ROOT" ] && continue
        uncommitted=$(git -C "$repo_root" status --porcelain 2>/dev/null | wc -l | xargs) || true
        unpushed=$(git -C "$repo_root" log --oneline @{u}.. 2>/dev/null | wc -l | xargs) || true
        if [ "$uncommitted" -gt 0 ] || [ "$unpushed" -gt 0 ]; then
            DIRTY_REPOS+=("$repo_root (uncommitted: $uncommitted, unpushed: $unpushed)")
        fi
    done < <(find "${DOTFILES_GITHUB_ROOT}" -mindepth 3 -maxdepth 4 -type d -name .git 2>/dev/null)

    if [ ${#DIRTY_REPOS[@]} -gt 0 ]; then
        dotfiles_ui_info "Repositories with uncommitted or unpushed changes:"
        for r in "${DIRTY_REPOS[@]}"; do
            echo "  • $r"
        done
        echo ""
        if ! confirm "Continue with uninstall anyway?"; then
            dotfiles_ui_info "Uninstall cancelled. Push your changes first."
            exit 0
        fi
    else
        dotfiles_ui_success "No dirty repositories found."
    fi
else
    dotfiles_ui_info "${DOTFILES_GITHUB_ROOT} does not exist, skipping check."
fi

# ─── 2. Remove ~/bin/ scripts ────────────────────────────────────────────────

section "Remove ~/bin/ scripts"

source "${SCRIPTS_ROOT}/lib/manifest.sh"

_found_bin=false
for entry in ${DOTFILES_BIN_SYMLINKS[@]+"${DOTFILES_BIN_SYMLINKS[@]}"} ${DOTFILES_DEPRECATED_BIN_SYMLINKS[@]+"${DOTFILES_DEPRECATED_BIN_SYMLINKS[@]}"}; do
    { [ -L "$HOME/bin/$entry" ] || [ -f "$HOME/bin/$entry" ]; } && _found_bin=true && break
done
[ -d "$HOME/bin/lib" ] && _found_bin=true

if [ "$_found_bin" = true ]; then
    if confirm "Remove dotfiles scripts from ~/bin/?"; then
        for entry in ${DOTFILES_BIN_SYMLINKS[@]+"${DOTFILES_BIN_SYMLINKS[@]}"} ${DOTFILES_DEPRECATED_BIN_SYMLINKS[@]+"${DOTFILES_DEPRECATED_BIN_SYMLINKS[@]}"}; do
            target="$HOME/bin/$entry"
            if [ -L "$target" ] || [ -f "$target" ]; then
                rm -f "$target"
                dotfiles_ui_success "  removed ~/bin/$entry"
            fi
        done
        if [ -d "$HOME/bin/lib" ]; then
            rm -rf "$HOME/bin/lib"
            dotfiles_ui_success "  removed ~/bin/lib/"
        fi
        if [ -d "$HOME/bin" ] && [ -z "$(ls -A "$HOME/bin" 2>/dev/null)" ]; then
            rmdir "$HOME/bin" && dotfiles_ui_success "  removed ~/bin/"
        fi
    fi
else
    dotfiles_ui_info "  No dotfiles scripts found in ~/bin/, skipping"
fi

# ─── 3. Remove shell aliases ──────────────────────────────────────────────────

section "Remove shell aliases from shell config"

SHELL_CONFIG="$(dotfiles_shell_config)"

if grep -q "# dotfiles aliases" "$SHELL_CONFIG" 2>/dev/null; then
    if confirm "Remove dotfiles aliases from ${SHELL_CONFIG}?"; then
        dotfiles_remove_lines_matching "$SHELL_CONFIG" "# dotfiles aliases"
        for alias_entry in ${DOTFILES_SHELL_ALIASES[@]+"${DOTFILES_SHELL_ALIASES[@]}"}; do
            alias_name="${alias_entry%%|*}"
            dotfiles_remove_lines_matching "$SHELL_CONFIG" "alias ${alias_name}="
        done
        dotfiles_ui_success "  Aliases removed"
    fi
else
    dotfiles_ui_info "  No dotfiles aliases found in ${SHELL_CONFIG}, skipping"
fi

# ─── 4. Remove PAT exports ────────────────────────────────────────────────────

section "Remove PAT exports from shell config"

if grep -q "GH_TOKEN_" "$SHELL_CONFIG" 2>/dev/null; then
    if confirm "Remove GH_TOKEN_* exports from ${SHELL_CONFIG}?"; then
        dotfiles_remove_lines_matching "$SHELL_CONFIG" "GH_TOKEN_"
        dotfiles_remove_lines_matching "$SHELL_CONFIG" "# dotfiles PAT"
        dotfiles_ui_success "  PAT exports removed"
    fi
else
    dotfiles_ui_info "  No GH_TOKEN exports found in ${SHELL_CONFIG}, skipping"
fi

# ─── 5. Remove XDG dotfiles.conf ─────────────────────────────────────────────

section "Remove XDG config"

XDG_CONF="${HOME}/.config/dotfiles/dotfiles.conf"
if [ -f "$XDG_CONF" ]; then
    if confirm "Remove ${XDG_CONF}?"; then
        rm -f "$XDG_CONF"
        rmdir "${HOME}/.config/dotfiles" 2>/dev/null || true
        dotfiles_ui_success "  Removed ${XDG_CONF}"
    fi
else
    dotfiles_ui_info "  ${XDG_CONF} not found, skipping"
fi

# ─── 6. Remove ~/bin PATH addition ───────────────────────────────────────────

section "Remove ~/bin from PATH in shell config"

if grep -qE "^[^#]*HOME/bin|# Add ~/bin to PATH" "$SHELL_CONFIG" 2>/dev/null; then
    if confirm "Remove ~/bin PATH addition from ${SHELL_CONFIG}?"; then
        dotfiles_remove_lines_matching "$SHELL_CONFIG" "# Add ~/bin to PATH"
        dotfiles_remove_lines_matching "$SHELL_CONFIG" 'HOME/bin:.*PATH'
        dotfiles_ui_success "  PATH entry removed"
    fi
else
    dotfiles_ui_info "  No ~/bin PATH entry found in ${SHELL_CONFIG}, skipping"
fi

# ─── 7. Remove SSH config blocks ─────────────────────────────────────────────

section "Remove SSH config blocks"

SSH_CONFIG="$HOME/.ssh/config"

_found_ssh_blocks=false
if [ -f "$SSH_CONFIG" ]; then
    for _u in ${DOTFILES_ACCOUNTS[@]+"${DOTFILES_ACCOUNTS[@]}"}; do
        _host="$(dotfiles_account_ssh_host "$_u")"
        for _prefix in "dotfiles-managed" "gitscripts-managed"; do
            grep -q "# ${_prefix}-begin ${_host}" "$SSH_CONFIG" 2>/dev/null && _found_ssh_blocks=true && break 2
        done
    done
fi
unset _u _host _prefix

if [ "$_found_ssh_blocks" = true ]; then
    if confirm "Remove dotfiles SSH host blocks from ~/.ssh/config?"; then
        for user in ${DOTFILES_ACCOUNTS[@]+"${DOTFILES_ACCOUNTS[@]}"}; do
            host="$(dotfiles_account_ssh_host "$user")"
            for prefix in "dotfiles-managed" "gitscripts-managed"; do
                marker_begin="# ${prefix}-begin ${host}"
                marker_end="# ${prefix}-end ${host}"
                if grep -q "$marker_begin" "$SSH_CONFIG" 2>/dev/null; then
                    if [[ "$(uname)" == "Darwin" ]]; then
                        sed -i '' "/${marker_begin}/,/${marker_end}/d" "$SSH_CONFIG" 2>/dev/null || true
                    else
                        sed -i "/${marker_begin}/,/${marker_end}/d" "$SSH_CONFIG" 2>/dev/null || true
                    fi
                    dotfiles_ui_success "  Removed SSH block for ${host} (${prefix})"
                fi
            done
        done
    fi
else
    dotfiles_ui_info "  No dotfiles SSH blocks found in ~/.ssh/config, skipping"
fi

# ─── 8. Remove git identity includeIf and per-account gitconfigs ─────────────

section "Remove git identity config"

_found_git_identity=false
for _u in ${DOTFILES_ACCOUNTS[@]+"${DOTFILES_ACCOUNTS[@]}"}; do
    [ -f "$HOME/.gitconfig-${_u}" ] && _found_git_identity=true && break
done
if [ "$_found_git_identity" = false ] && [ -f "$HOME/.gitconfig" ]; then
    grep -q 'includeIf "gitdir:.*Documents/GitHub' "$HOME/.gitconfig" 2>/dev/null && _found_git_identity=true
fi
unset _u

if [ "$_found_git_identity" = true ]; then
    if confirm "Remove includeIf blocks and ~/.gitconfig-<user> files?"; then
        for user in ${DOTFILES_ACCOUNTS[@]+"${DOTFILES_ACCOUNTS[@]}"}; do
            cfg="$HOME/.gitconfig-${user}"
            if [ -f "$cfg" ]; then
                rm -f "$cfg"
                dotfiles_ui_success "  Removed $cfg"
            fi
        done
        if [ -f "$HOME/.gitconfig" ]; then
            if [[ "$(uname)" == "Darwin" ]]; then
                sed -i '' '/\[includeIf "gitdir:.*Documents\/GitHub/,/path = ~\/.gitconfig-/d' "$HOME/.gitconfig" 2>/dev/null || true
            else
                sed -i '/\[includeIf "gitdir:.*Documents\/GitHub/,/path = ~\/.gitconfig-/d' "$HOME/.gitconfig" 2>/dev/null || true
            fi
            dotfiles_ui_success "  Removed includeIf blocks from ~/.gitconfig"
        fi
    fi
else
    dotfiles_ui_info "  No git identity config found, skipping"
fi

# ─── 9. Remove SSH keys ──────────────────────────────────────────────────────

section "Remove SSH keys"

if [ -d "$DOTFILES_SSH_DIR" ]; then
    if confirm "Remove dotfiles SSH keys from ${DOTFILES_SSH_DIR}?"; then
        rm -rf "$DOTFILES_SSH_DIR"
        dotfiles_ui_success "  Removed ${DOTFILES_SSH_DIR}"
    fi
else
    dotfiles_ui_info "  ${DOTFILES_SSH_DIR} not found, skipping"
fi

# ─── 10. Uninstall apps ───────────────────────────────────────────────────────

section "Uninstall apps"

[ -d "/Applications/Claude.app" ]   && { confirm "Uninstall Claude desktop?" && brew_uninstall claude --cask; } || dotfiles_ui_info "  Claude desktop not installed, skipping"
if command -v claude &>/dev/null; then
    if confirm "Uninstall Claude CLI?"; then
        command -v npm &>/dev/null && npm uninstall -g @anthropic-ai/claude-code 2>/dev/null || true
        dotfiles_ui_success "  Claude CLI removed"
    fi
else
    dotfiles_ui_info "  Claude CLI not installed, skipping"
fi
[ -d "/Applications/Cursor.app" ]       && { confirm "Uninstall Cursor?"       && brew_uninstall cursor --cask; }       || dotfiles_ui_info "  Cursor not installed, skipping"
[ -d "/Applications/Warp.app" ]         && { confirm "Uninstall Warp?"         && brew_uninstall warp --cask; }         || dotfiles_ui_info "  Warp not installed, skipping"
[ -d "/Applications/Ghostty.app" ]      && { confirm "Uninstall Ghostty?"      && brew_uninstall ghostty --cask; }      || dotfiles_ui_info "  Ghostty not installed, skipping"
[ -d "/Applications/iTerm.app" ]        && { confirm "Uninstall iTerm2?"       && brew_uninstall iterm2 --cask; }       || dotfiles_ui_info "  iTerm2 not installed, skipping"
[ -d "/Applications/Raycast.app" ]      && { confirm "Uninstall Raycast?"      && brew_uninstall raycast --cask; }      || dotfiles_ui_info "  Raycast not installed, skipping"
[ -d "/Applications/Typora.app" ]       && { confirm "Uninstall Typora?"       && brew_uninstall typora --cask; }       || dotfiles_ui_info "  Typora not installed, skipping"
[ -d "/Applications/Arc.app" ]          && { confirm "Uninstall Arc?"          && brew_uninstall arc --cask; }          || dotfiles_ui_info "  Arc not installed, skipping"
[ -d "/Applications/Zed.app" ]          && { confirm "Uninstall Zed?"          && brew_uninstall zed --cask; }          || dotfiles_ui_info "  Zed not installed, skipping"
[ -d "/Applications/Sublime Text.app" ] && { confirm "Uninstall Sublime Text?" && brew_uninstall sublime-text --cask; } || dotfiles_ui_info "  Sublime Text not installed, skipping"
[ -d "/Applications/TextMate.app" ]     && { confirm "Uninstall TextMate?"     && brew_uninstall textmate --cask; }     || dotfiles_ui_info "  TextMate not installed, skipping"

# ─── 11. Remove Oh My Zsh and Powerlevel10k ──────────────────────────────────

section "Remove Oh My Zsh and Powerlevel10k"

_omz_zshrc_refs=false
grep -q "oh-my-zsh" "$HOME/.zshrc" 2>/dev/null && _omz_zshrc_refs=true

if [ -d "$HOME/.oh-my-zsh" ]; then
    if confirm "Remove Oh My Zsh (~/.oh-my-zsh)?"; then
        rm -rf "$HOME/.oh-my-zsh"
        dotfiles_ui_success "  Removed ~/.oh-my-zsh"
        if [ "$_omz_zshrc_refs" = true ] && [ -f "$HOME/.zshrc" ]; then
            dotfiles_remove_lines_matching "$HOME/.zshrc" 'oh-my-zsh\.sh'
            dotfiles_remove_lines_matching "$HOME/.zshrc" 'export ZSH='
            dotfiles_remove_lines_matching "$HOME/.zshrc" 'ZSH_THEME='
            dotfiles_remove_lines_matching "$HOME/.zshrc" 'zsh-syntax-highlighting\.zsh'
            # Remove entire p10k instant-prompt if/fi block
            sed -i '' '/p10k-instant-prompt/,/^fi$/d' "$HOME/.zshrc" 2>/dev/null || true
            dotfiles_remove_lines_matching "$HOME/.zshrc" 'p10k\.zsh'
            dotfiles_remove_lines_matching "$HOME/.zshrc" 'POWERLEVEL9K_DISABLE'
            dotfiles_ui_success "  Removed oh-my-zsh references from ~/.zshrc"
        fi
    fi
elif [ "$_omz_zshrc_refs" = true ] && [ -f "$HOME/.zshrc" ]; then
    dotfiles_remove_lines_matching "$HOME/.zshrc" 'oh-my-zsh\.sh'
    dotfiles_remove_lines_matching "$HOME/.zshrc" 'export ZSH='
    dotfiles_remove_lines_matching "$HOME/.zshrc" 'ZSH_THEME='
    dotfiles_remove_lines_matching "$HOME/.zshrc" 'zsh-syntax-highlighting\.zsh'
    # Remove entire p10k instant-prompt if/fi block
    sed -i '' '/p10k-instant-prompt/,/^fi$/d' "$HOME/.zshrc" 2>/dev/null || true
    dotfiles_remove_lines_matching "$HOME/.zshrc" 'p10k\.zsh'
    dotfiles_remove_lines_matching "$HOME/.zshrc" 'POWERLEVEL9K_DISABLE'
    dotfiles_ui_success "  Cleaned leftover oh-my-zsh references from ~/.zshrc"
else
    dotfiles_ui_info "  Oh My Zsh not found, skipping"
fi

if [ -f "$HOME/.p10k.zsh" ]; then
    if confirm "Remove ~/.p10k.zsh?"; then
        rm -f "$HOME/.p10k.zsh"
        dotfiles_ui_success "  Removed ~/.p10k.zsh"
    fi
else
    dotfiles_ui_info "  ~/.p10k.zsh not found, skipping"

fi

# ─── 12. Remove per-account repo folders ─────────────────────────────────────

section "Remove per-account repository folders"

if [ "$KEEP_REPOS" = true ]; then
    dotfiles_ui_info "  Skipped (--keep-repos)"
else
    dotfiles_ui_info "This removes only the account folders created by dotfiles_install."
    dotfiles_ui_info "The GitHub root (${DOTFILES_GITHUB_ROOT}) itself is kept."
    echo ""

    for user in ${DOTFILES_ACCOUNTS[@]+"${DOTFILES_ACCOUNTS[@]}"}; do
        user_dir="${DOTFILES_GITHUB_ROOT}/${user}"
        if [ -d "$user_dir" ]; then
            # Never delete the folder that contains this running script
            if [[ "$REPO_ROOT" == "${user_dir}"/* ]]; then
                dotfiles_ui_info "  Skipping ${user_dir} — contains the running dotfiles repo"
                dotfiles_ui_info "  Delete manually after uninstall if needed: rm -rf ${user_dir}"
                continue
            fi
            dotfiles_ui_info "WARNING: This will delete all repos for ${user}: ${user_dir}"
            if confirm "Delete ${user_dir}?"; then
                rm -rf "$user_dir"
                dotfiles_ui_success "  Removed ${user_dir}"
            fi
        else
            dotfiles_ui_info "  ${user_dir} not found, skipping"
        fi
    done
fi

# ─── 13. Remove Dock icons ────────────────────────────────────────────────────

section "Remove Dock icons"

DOCK_APPS=("iTerm" "Ghostty" "Warp" "Cursor" "Claude" "Raycast" "Typora" "Arc" "Zed" "Sublime Text" "TextMate")

if command -v dockutil &>/dev/null; then
    dock_changed=false
    for app in "${DOCK_APPS[@]}"; do
        if defaults read com.apple.dock persistent-apps 2>/dev/null | grep -q "file-label\" = \"*${app}"; then
            if confirm "Remove ${app} from Dock?"; then
                dockutil --remove "$app" --no-restart 2>/dev/null || true
                dotfiles_ui_success "  Removed ${app} from Dock"
                dock_changed=true
            fi
        else
            dotfiles_ui_info "  ${app} not in Dock, skipping"
        fi
    done
    [ "$dock_changed" = true ] && killall Dock 2>/dev/null || true
else
    dotfiles_ui_info "  dockutil not found, skipping"
fi

# ─── 14. Reset default shell ─────────────────────────────────────────────────

section "Reset default shell"

_current_shell="$(dscl . -read /Users/"$(whoami)" UserShell 2>/dev/null | awk '{print $2}')"
if [[ "$_current_shell" == /opt/homebrew/* ]] || [[ "$_current_shell" == /usr/local/* ]]; then
    if confirm "Reset default shell from ${_current_shell} to /bin/zsh?"; then
        chsh -s /bin/zsh
        dotfiles_ui_success "  Default shell reset to /bin/zsh"
    fi
else
    dotfiles_ui_info "  Default shell is ${_current_shell} — no reset needed"
fi
unset _current_shell

# ─── 15. Remove Homebrew ──────────────────────────────────────────────────────

section "Remove Homebrew"

if command -v brew &>/dev/null; then
    dotfiles_ui_info "WARNING: This will remove Homebrew and all packages installed through it."
    if confirm "Uninstall Homebrew?"; then
        NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/uninstall.sh)"
        dotfiles_ui_success "  Homebrew removed"
    else
        dotfiles_ui_info "  Homebrew kept"
    fi
else
    dotfiles_ui_info "  Homebrew not found, skipping"
fi

# ─── Done ─────────────────────────────────────────────────────────────────────

section "Uninstall complete"

dotfiles_ui_success "dotfiles environment removed."
echo ""
dotfiles_ui_info "To apply changes to your current shell session:"
echo "  source $(dotfiles_shell_config)"
echo "  (or open a new terminal)"
echo ""
if [[ "$REPO_ROOT" == "${DOTFILES_GITHUB_ROOT}"/* ]]; then
    dotfiles_ui_info "NOTE: The dotfiles repo itself was not deleted:"
    echo "  ${REPO_ROOT}"
    dotfiles_ui_info "Delete it manually when you are done:"
    echo "  rm -rf ${REPO_ROOT}"
fi
