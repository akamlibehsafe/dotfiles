# dotfiles.conf.example — template only (safe to commit)
#
# Copy to dotfiles.conf and fill in your real values:
#   cp dotfiles.conf.example dotfiles.conf
#
# NEVER commit dotfiles.conf — it contains your PATs.
# It is listed in .gitignore.
#
# ─────────────────────────────────────────────────────────────────────────────
# WHERE TO GET YOUR PATs
#   GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
#   Click "Generate new token (classic)"
#   Required scope: repo (full control of private repositories)
#   Recommended expiration: No expiration
#   Token format: ghp_ followed by 40 characters
# ─────────────────────────────────────────────────────────────────────────────

# Where your GitHub repositories are stored (one folder per username under here)
github_root=~/Documents/GitHub

# ─── Account blocks ───────────────────────────────────────────────────────────
# One block per GitHub account.
# account     <github-username> <commit-email> [Display Name]
# pat         <your-classic-PAT-token>

account youruser you@example.com "Your Name"
pat ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

account yourotheruser other@example.com "Other Name"
pat ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── Optional: skip bulk clone for an account during dotfiles_install ─────────
# clone youruser no

# ─── Optional: shell aliases (path under github_root, or "." = github_root) ──
alias cdg .
alias cda youruser
alias cdf yourotheruser
