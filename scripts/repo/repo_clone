#!/bin/bash
# repo_clone — clone an existing GitHub repository into the correct folder
# Clones into ~/Documents/GitHub/<user>/<repo>/ using HTTPS with username-scoped auth.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
_script_dir="$(cd "$(dirname "$_self")" && pwd -P)"
# When copied to ~/bin/, lib/ is a sibling dir. In the repo, lib/ is one level up.
if [ -d "${_script_dir}/lib" ]; then
    SCRIPTS_ROOT="$_script_dir"
else
    SCRIPTS_ROOT="$(cd "${_script_dir}/.." && pwd -P)"
fi

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

# ─── usage ────────────────────────────────────────────────────────────────────

usage() {
    echo "Usage: repo_clone <user/repo>"
    echo ""
    echo "  Clone an existing GitHub repository into:"
    echo "  ${DOTFILES_GITHUB_ROOT}/<user>/<repo>/"
    echo ""
    echo "Arguments:"
    echo "  user/repo   GitHub username and repository name"
    echo ""
    echo "Examples:"
    echo "  repo_clone fortegb/my-project"
    echo "  repo_clone akamlibehsafe/my-tool"
    echo ""
    echo "Configured accounts: $(dotfiles_accounts_list)"
    exit 0
}

# ─── args ─────────────────────────────────────────────────────────────────────

[ $# -eq 1 ] || dotfiles_usage_error "Expected exactly one argument: user/repo" "repo_clone <user/repo>"
[ "$1" = "-h" ] || [ "$1" = "--help" ] && usage

USER_REPO="$1"
[[ "$USER_REPO" =~ ^[^/]+/[^/]+$ ]] || \
    dotfiles_usage_error "Invalid format '${USER_REPO}' — expected user/repo" "repo_clone <user/repo>"

USERNAME="$(echo "$USER_REPO" | cut -d'/' -f1)"
REPO_NAME="$(echo "$USER_REPO" | cut -d'/' -f2)"

dotfiles_is_known_account "$USERNAME" || \
    dotfiles_die "Unknown account: ${USERNAME}\nConfigured accounts: $(dotfiles_accounts_list)"

# ─── destination ──────────────────────────────────────────────────────────────

DEST="${DOTFILES_GITHUB_ROOT}/${USERNAME}/${REPO_NAME}"

[ -d "$DEST" ] && \
    dotfiles_die "Destination already exists: ${DEST}\nRemove it first or use git pull inside."

CLONE_URL="$(dotfiles_remote_https_url "$USERNAME" "$REPO_NAME")"

dotfiles_ui_info "Cloning : ${USER_REPO}"
dotfiles_ui_info "From    : ${CLONE_URL}"
dotfiles_ui_info "Into    : ${DEST}"
echo ""

command -v git &>/dev/null || dotfiles_die "git not found. Run dotfiles_install first."

# ─── clone ────────────────────────────────────────────────────────────────────

mkdir -p "${DOTFILES_GITHUB_ROOT}/${USERNAME}"

set +e
git -c credential.helper= clone "$CLONE_URL" "$DEST" 2>&1
CLONE_STATUS=$?
set -e

if [ "$CLONE_STATUS" -ne 0 ]; then
    dotfiles_die "Clone failed.\nCheck that the repo exists and credentials are configured:\n  scripts/setup/setup_check"
fi

dotfiles_ui_success "Cloned successfully."

# ─── git LFS ──────────────────────────────────────────────────────────────────

cd "$DEST"

if command -v git-lfs &>/dev/null || git lfs version &>/dev/null 2>&1; then
    if [ -f .gitattributes ] || git lfs ls-files &>/dev/null 2>&1; then
        dotfiles_ui_info "Pulling Git LFS files..."
        git lfs install --local 2>/dev/null || true
        git lfs pull 2>&1 | head -20 || true
    fi
fi

# ─── bake git identity into .git/config ──────────────────────────────────────

GIT_NAME="$(dotfiles_account_git_name "$USERNAME")"
GIT_EMAIL="$(dotfiles_account_email "$USERNAME")"
git config --local user.name  "$GIT_NAME"
git config --local user.email "$GIT_EMAIL"
dotfiles_ui_success "Identity : ${GIT_NAME} <${GIT_EMAIL}>"

# ─── copy AI context templates ───────────────────────────────────────────────

_templates_dir="$(cd "${_script_dir}" && cd "$(git -C "${_script_dir}" rev-parse --show-toplevel 2>/dev/null || echo "${_script_dir}/..")" && pwd -P)/templates"
if [ ! -d "$_templates_dir" ]; then
    _dotfiles_repo="$(dirname "$(readlink -f "${HOME}/.config/dotfiles/dotfiles.conf" 2>/dev/null || echo "")" 2>/dev/null || true)"
    [ -d "${_dotfiles_repo}/templates" ] && _templates_dir="${_dotfiles_repo}/templates"
fi

if [ -d "$_templates_dir" ]; then
    _added=false
    for _tmpl in AGENTS.md DECISIONS.md; do
        if [ ! -f "$_tmpl" ] && [ -f "${_templates_dir}/${_tmpl}" ]; then
            cp "${_templates_dir}/${_tmpl}" "./${_tmpl}"
            git add "$_tmpl" 2>/dev/null || true
            dotfiles_ui_success "  Created ${_tmpl} from template"
            _added=true
        fi
    done
    if [ "$_added" = true ]; then
        git commit -m "Add AI context files (AGENTS.md, DECISIONS.md)" 2>/dev/null || true
        dotfiles_ui_success "  AI context files committed"
    fi
else
    dotfiles_ui_info "  templates/ not found — skipping AI context files"
fi
unset _templates_dir _dotfiles_repo _tmpl _added

# ─── summary ──────────────────────────────────────────────────────────────────

echo ""
dotfiles_ui_success "Repository ready at: ${DEST}"
echo "  Remote   : $(git remote get-url origin)"
echo "  Branch   : $(git branch --show-current)"
echo "  Identity : $(git config user.email)"
