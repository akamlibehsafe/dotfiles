#!/bin/bash
# setup_configure_pats — per-account PAT wizard (PAT.md + optional ~/.zshrc)

set -euo pipefail

_gitscripts_self="${BASH_SOURCE[0]}"
while [ -L "$_gitscripts_self" ]; do
    _d="$(cd "$(dirname "$_gitscripts_self")" && pwd)"
    _gitscripts_self="$(readlink "$_gitscripts_self")"
    [[ "$_gitscripts_self" != /* ]] && _gitscripts_self="$_d/$_gitscripts_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_gitscripts_self")" && pwd -P)"
SCRIPTS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
# shellcheck source=lib/init.sh
source "${SCRIPTS_ROOT}/lib/init.sh"
gitscripts_ui_colors

REPO_ROOT="${GITSCRIPTS_REPO_ROOT}"
PAT_FILE="${GITSCRIPTS_PAT_FILE:-${REPO_ROOT}/PAT.md}"
FORCE=false
WRITE_ZSHRC=true

usage() {
    echo "Usage: setup_configure_pats [--force] [--no-zshrc]"
    echo ""
    echo "  --force       Re-prompt even when PAT validates"
    echo "  --no-zshrc    Only update PAT.md, not ~/.zshrc"
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --force) FORCE=true; shift ;;
        --no-zshrc) WRITE_ZSHRC=false; shift ;;
        -h|--help) usage ;;
        *) gitscripts_ui_error "Unknown option: $1"; usage ;;
    esac
done

gitscripts_load_pat_file "$PAT_FILE" 2>/dev/null || true

detect_shell_config() {
    local shell_name
    shell_name=$(basename "${SHELL:-zsh}")
    if [ "$shell_name" = "zsh" ]; then
        echo "$HOME/.zshrc"
    elif [ -f "$HOME/.bash_profile" ]; then
        echo "$HOME/.bash_profile"
    else
        echo "$HOME/.bashrc"
    fi
}

upsert_pat_export() {
    local file="$1"
    local var="$2"
    local value="$3"
    touch "$file"
    if grep -q "^export ${var}=" "$file" 2>/dev/null; then
        if [[ "$(uname)" == "Darwin" ]]; then
            sed -i '' "s|^export ${var}=.*|export ${var}=\"${value}\"|" "$file"
        else
            sed -i "s|^export ${var}=.*|export ${var}=\"${value}\"|" "$file"
        fi
    else
        {
            echo ""
            echo "# gitscripts PAT (${var})"
            echo "export ${var}=\"${value}\""
        } >>"$file"
    fi
}

remove_old_pat_lines() {
    local file="$1"
    [ -f "$file" ] || return 0
    if [[ "$(uname)" == "Darwin" ]]; then
        sed -i '' '/^export GH_TOKEN_/d' "$file" 2>/dev/null || true
    else
        sed -i '/^export GH_TOKEN_/d' "$file" 2>/dev/null || true
    fi
}

rebuild_pat_md() {
    local tmp
    tmp=$(mktemp)
    {
        echo "# Personal Access Tokens (gitscripts)"
        echo "# Generated by setup_configure_pats — do not commit"
        echo ""
        for user in "${GITSCRIPTS_ACCOUNTS[@]}"; do
            local var val
            var=$(gitscripts_account_pat_var "$user")
            val="${!var:-}"
            if [ -n "$val" ]; then
                echo "export ${var}=\"${val}\""
            fi
        done
    } >"$tmp"
    mv "$tmp" "$PAT_FILE"
    chmod 600 "$PAT_FILE" 2>/dev/null || true
}

gitscripts_ui_section "Configure GitHub PATs"

echo "PAT file: ${PAT_FILE}"
echo "Classic PAT with 'repo' scope: https://github.com/settings/tokens"
echo ""

for user in "${GITSCRIPTS_ACCOUNTS[@]}"; do
    pat_var=$(gitscripts_account_pat_var "$user")
    status=$(gitscripts_verify_pat_api "$pat_var" "$user" || true)

    if [ "$status" = "ok" ] && [ "$FORCE" = false ]; then
        gitscripts_ui_success "Skipping ${user} — ${pat_var} already valid"
        continue
    fi

    gitscripts_ui_prompt "Account: ${user}"
    echo "  1. Log into GitHub as ${user}"
    echo "  2. Settings → Developer settings → Personal access tokens → Generate (classic)"
    echo "  3. Enable 'repo' scope, no expiration (or your preference)"
    echo ""
    read -r -s -p "Paste PAT for ${user} (input hidden): " token
    echo ""

    if [ -z "$token" ]; then
        gitscripts_ui_info "  Skipped (empty input)"
        continue
    fi

    export "${pat_var}=${token}"
    status=$(gitscripts_verify_pat_api "$pat_var" "$user" || true)
    if [ "$status" != "ok" ]; then
        gitscripts_ui_error "  Token failed verification: ${status}"
        unset "${pat_var}"
        continue
    fi

    gitscripts_ui_success "  ${pat_var} verified for ${user}"
done

rebuild_pat_md
gitscripts_ui_success "Wrote ${PAT_FILE}"

if [ "$WRITE_ZSHRC" = true ]; then
    SHELL_CONFIG=$(detect_shell_config)
    gitscripts_ui_info "Updating ${SHELL_CONFIG} (removes old GH_TOKEN_* lines first)"
    remove_old_pat_lines "$SHELL_CONFIG"
    for user in "${GITSCRIPTS_ACCOUNTS[@]}"; do
        pat_var=$(gitscripts_account_pat_var "$user")
        val="${!pat_var:-}"
        if [ -n "$val" ]; then
            upsert_pat_export "$SHELL_CONFIG" "$pat_var" "$val"
        fi
    done
    gitscripts_ui_success "Shell config updated. Run: source ${SHELL_CONFIG}"
fi

gitscripts_ui_section "Done"
echo "Verify with: ./scripts/util/setup_preflight"
