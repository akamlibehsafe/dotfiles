#!/bin/bash
# setup_preflight — read-only scan of PAT, SSH, gitconfig, and remotes

set -euo pipefail

_gitscripts_self="${BASH_SOURCE[0]}"
while [ -L "$_gitscripts_self" ]; do
    _d="$(cd "$(dirname "$_gitscripts_self")" && pwd)"
    _gitscripts_self="$(readlink "$_gitscripts_self")"
    [[ "$_gitscripts_self" != /* ]] && _gitscripts_self="$_d/$_gitscripts_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_gitscripts_self")" && pwd -P)"
SCRIPTS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
# shellcheck source=lib/init.sh
source "${SCRIPTS_ROOT}/lib/init.sh"
gitscripts_ui_colors

REPO_ROOT="${GITSCRIPTS_REPO_ROOT}"
PAT_FILE="${GITSCRIPTS_PAT_FILE:-${REPO_ROOT}/PAT.md}"

gitscripts_load_pat_file "$PAT_FILE" 2>/dev/null || true
gitscripts_load_pat_from_shell_configs

ACTIONS=()
PAT_OK=0
PAT_TOTAL=${#GITSCRIPTS_ACCOUNTS[@]}
SSH_OK=0
SSH_TOTAL=${#GITSCRIPTS_ACCOUNTS[@]}
INCLUDE_OK=0
HTTPS_REMOTES=0
SSH_REMOTES=0
REPO_COUNT=0

gitscripts_ui_section "setup preflight (read-only)"

echo "Repository: ${REPO_ROOT}"
echo "GitHub root: ${GITSCRIPTS_GITHUB_ROOT}"
echo "SSH keys dir: ${GITSCRIPTS_SSH_DIR}"
echo "PAT file: ${PAT_FILE}"
echo ""

gitscripts_ui_section "Personal access tokens (API)"

for user in "${GITSCRIPTS_ACCOUNTS[@]}"; do
    pat_var=$(gitscripts_account_pat_var "$user")
    status=$(gitscripts_verify_pat_api "$pat_var" "$user" || true)
    case "$status" in
        ok)
            gitscripts_ui_success "  ${pat_var}: valid (${user})"
            PAT_OK=$((PAT_OK + 1))
            ;;
        missing)
            gitscripts_ui_info "  ${pat_var}: not set"
            ACTIONS+=("configure_pat:${user}")
            ;;
        wrong_user:*)
            gitscripts_ui_error "  ${pat_var}: wrong GitHub user (${status#wrong_user:})"
            ACTIONS+=("configure_pat:${user}")
            ;;
        *)
            gitscripts_ui_error "  ${pat_var}: ${status}"
            ACTIONS+=("configure_pat:${user}")
            ;;
    esac
done

gitscripts_ui_section "SSH keys and config"

mkdir -p "$GITSCRIPTS_SSH_DIR" 2>/dev/null || true

for user in "${GITSCRIPTS_ACCOUNTS[@]}"; do
    key=$(gitscripts_account_key_path "$user")
    host=$(gitscripts_account_ssh_host "$user")
    key_ok=false
    config_ok=false

    if [ -f "$key" ] && [ -f "${key}.pub" ]; then
        key_ok=true
        gitscripts_ui_success "  Key exists: ${key}"
    else
        gitscripts_ui_info "  Key missing: ${key}"
        ACTIONS+=("ssh_generate:${user}")
    fi

    if [ -f "$HOME/.ssh/config" ] && grep -q "Host ${host}" "$HOME/.ssh/config" 2>/dev/null; then
        config_ok=true
        gitscripts_ui_success "  SSH config Host ${host}: present"
    else
        gitscripts_ui_info "  SSH config Host ${host}: missing"
        ACTIONS+=("ssh_config:${user}")
    fi

    if [ "$key_ok" = true ] && [ "$config_ok" = true ]; then
        ssh_out=$(ssh -o BatchMode=yes -o ConnectTimeout=8 -T "git@${host}" 2>&1 || true)
        if echo "$ssh_out" | grep -qi "successfully authenticated"; then
            gitscripts_ui_success "  ssh -T git@${host}: authenticated"
            SSH_OK=$((SSH_OK + 1))
        else
            gitscripts_ui_info "  ssh -T git@${host}: not verified (key on GitHub?)"
            ACTIONS+=("ssh_github_key:${user}")
        fi
    fi
done

gitscripts_ui_section "Git identity (includeIf)"

if [ -f "$HOME/.gitconfig" ]; then
    for user in "${GITSCRIPTS_ACCOUNTS[@]}"; do
        gitdir=$(gitscripts_account_gitdir "$user")
        inc="gitdir:${gitdir}"
        cfg="$HOME/.gitconfig-${user}"
        if grep -Fq "$inc" "$HOME/.gitconfig" 2>/dev/null && [ -f "$cfg" ]; then
            gitscripts_ui_success "  ${inc} -> ${cfg}"
            INCLUDE_OK=$((INCLUDE_OK + 1))
        else
            gitscripts_ui_info "  ${inc}: incomplete"
            ACTIONS+=("gitconfig_include:${user}")
        fi
    done
else
    gitscripts_ui_info "  ~/.gitconfig not found"
    ACTIONS+=("gitconfig_global")
fi

gitscripts_ui_section "Remotes under ${GITSCRIPTS_GITHUB_ROOT}"

if [ -d "$GITSCRIPTS_GITHUB_ROOT" ]; then
    while IFS= read -r git_dir; do
        [ -z "$git_dir" ] && continue
        REPO_COUNT=$((REPO_COUNT + 1))
        repo_root=$(dirname "$git_dir")
        origin=$(git -C "$repo_root" remote get-url origin 2>/dev/null || echo "")
        [ -z "$origin" ] && continue
        if [[ "$origin" =~ ^https://github\.com/ ]] || [[ "$origin" =~ ^http://github\.com/ ]]; then
            HTTPS_REMOTES=$((HTTPS_REMOTES + 1))
            echo "  HTTPS: ${repo_root}"
        elif [[ "$origin" =~ ^git@github- ]]; then
            SSH_REMOTES=$((SSH_REMOTES + 1))
        fi
    done < <(find "$GITSCRIPTS_GITHUB_ROOT" -mindepth 3 -maxdepth 4 -type d -name .git 2>/dev/null)
    echo ""
    echo "  Repos scanned: ${REPO_COUNT}"
    echo "  HTTPS origins: ${HTTPS_REMOTES}"
    echo "  SSH alias origins: ${SSH_REMOTES}"
    if [ "$HTTPS_REMOTES" -gt 0 ]; then
        ACTIONS+=("migrate_remotes")
    fi
else
    gitscripts_ui_info "  ${GITSCRIPTS_GITHUB_ROOT} does not exist yet"
    ACTIONS+=("create_github_root")
fi

# Profile
PROFILE="partial"
if [ "$PAT_OK" -eq "$PAT_TOTAL" ] && [ "$SSH_OK" -eq "$SSH_TOTAL" ] && [ "$INCLUDE_OK" -eq "$PAT_TOTAL" ] && [ "$HTTPS_REMOTES" -eq 0 ]; then
    PROFILE="configured"
elif [ "$PAT_OK" -eq 0 ] && [ "$SSH_OK" -eq 0 ] && [ "$INCLUDE_OK" -eq 0 ]; then
    PROFILE="greenfield"
fi

gitscripts_ui_section "Summary"
echo "  Profile: ${PROFILE}"
echo "  PATs OK: ${PAT_OK}/${PAT_TOTAL}"
echo "  SSH auth OK: ${SSH_OK}/${SSH_TOTAL}"
echo "  includeIf OK: ${INCLUDE_OK}/${PAT_TOTAL}"

if [ ${#ACTIONS[@]} -gt 0 ]; then
    echo ""
    gitscripts_ui_info "Suggested next steps (run manually after review):"
    while IFS= read -r action; do
        [ -n "$action" ] && echo "  - ${action}"
    done < <(printf '%s\n' "${ACTIONS[@]}" | sort -u)
    echo ""
    echo "  ./scripts/util/setup_configure_pats    # if PATs missing"
    echo "  ./scripts/util/setup_ssh_setup --dry-run"
    echo "  ./scripts/util/setup_ssh_setup --repair   # after dry-run OK"
    echo "  ./scripts/util/setup_migrate_remotes --dry-run"
else
    gitscripts_ui_success "No actions required — environment looks ready."
fi

echo ""
exit 0
