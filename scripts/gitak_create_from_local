#!/bin/bash

# gitak_create_from_local
# Initializes a local folder and pushes to an existing GitHub repo (create repo on GitHub first).

set -e

_gitscripts_self="${BASH_SOURCE[0]}"
while [ -L "$_gitscripts_self" ]; do
    _d="$(cd "$(dirname "$_gitscripts_self")" && pwd)"
    _gitscripts_self="$(readlink "$_gitscripts_self")"
    [[ "$_gitscripts_self" != /* ]] && _gitscripts_self="$_d/$_gitscripts_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_gitscripts_self")" && pwd -P)"
# shellcheck source=lib/gitscripts_init.sh
source "${SCRIPT_DIR}/lib/gitscripts_init.sh"
gitscripts_load_pat_file "${SCRIPT_DIR}/../PAT.md" 2>/dev/null || true
gitscripts_load_pat_from_shell_configs

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

error() { echo -e "${RED}Error: $1${NC}" >&2; exit 1; }
success() { echo -e "${GREEN}$1${NC}"; }
info() { echo -e "${YELLOW}$1${NC}"; }
prompt() { echo -e "${BLUE}$1${NC}"; }

if [ $# -ne 1 ]; then
    error "Usage: gitak_create_from_local <user/repo>\nExample: gitak_create_from_local akamlibehsafe/myproject"
fi

USER_REPO="$1"
if [[ ! "$USER_REPO" =~ ^[^/]+/[^/]+$ ]]; then
    error "Invalid format. Expected: user/repo"
fi

USERNAME=$(echo "$USER_REPO" | cut -d'/' -f1)
REPO_NAME=$(echo "$USER_REPO" | cut -d'/' -f2)

if ! gitscripts_is_known_account "$USERNAME"; then
    error "Unknown username: $USERNAME\nSupported: $(gitscripts_supported_accounts_list)"
fi

SSH_REMOTE=$(gitscripts_remote_ssh_url "$USERNAME" "$REPO_NAME")

info "Repository: $USER_REPO"
info "SSH remote: $SSH_REMOTE"

if ! command -v git &>/dev/null; then
    error "Git is not installed. Run gitak_install first."
fi

CURRENT_DIR=$(pwd -P)
info "Working directory: $CURRENT_DIR"

if [[ "$CURRENT_DIR" =~ ^/tmp|^/private/tmp|^/var/tmp ]]; then
    SAFE_DIRS=$(git config --global --get-all safe.directory 2>/dev/null || echo "")
    if [ -z "$SAFE_DIRS" ] || ! echo "$SAFE_DIRS" | grep -Fxq "$CURRENT_DIR"; then
        git config --global --add safe.directory "$CURRENT_DIR"
    fi
fi

prompt "Create an empty repository on GitHub first (no README if this folder has files):"
echo "  https://github.com/new?name=${REPO_NAME}"
echo "  Owner must be: ${USERNAME}"
read -r -p "Press Enter after the repo exists on GitHub..."

set +e
git ls-remote "$SSH_REMOTE" &>/dev/null
REMOTE_OK=$?
set -e
if [ "$REMOTE_OK" -ne 0 ]; then
    error "Cannot reach $SSH_REMOTE.\nCreate the repo on GitHub and ensure SSH is set up: gitscripts_ssh_setup --repair"
fi
success "Remote repository found"

HAS_LFS=false
if command -v git-lfs &>/dev/null || git lfs version &>/dev/null 2>&1; then
    HAS_LFS=true
fi

if [ ! -d ".git" ]; then
    info "Initializing Git repository..."
    git init
    success "Git repository initialized"
fi

LARGE_FILE_THRESHOLD=104857600
LARGE_FILES=$(find . -type f -size +${LARGE_FILE_THRESHOLD}c -not -path './.git/*' 2>/dev/null | head -20)
if [ -n "$LARGE_FILES" ] && [ "$HAS_LFS" = true ]; then
    info "Large files detected, configuring Git LFS..."
    git lfs install --local 2>/dev/null || git lfs install 2>/dev/null || true
    EXTENSIONS=$(echo "$LARGE_FILES" | sed 's/.*\.//' | sort -u | grep -v '^$' | head -10)
    touch .gitattributes
    for ext in $EXTENSIONS; do
        if ! grep -q "\.${ext}" .gitattributes 2>/dev/null; then
            echo "*.${ext} filter=lfs diff=lfs merge=lfs -text" >> .gitattributes
        fi
    done
fi

DEFAULT_BRANCH=$(git config --global init.defaultBranch 2>/dev/null || echo "main")
[ "$DEFAULT_BRANCH" != "main" ] && [ "$DEFAULT_BRANCH" != "master" ] && DEFAULT_BRANCH="main"

if git remote get-url origin &>/dev/null; then
    git remote set-url origin "$SSH_REMOTE"
else
    git remote add origin "$SSH_REMOTE"
fi
success "Remote origin: $SSH_REMOTE"

HAS_COMMITS=false
if git rev-parse --verify HEAD &>/dev/null; then
    HAS_COMMITS=true
fi

if [ -n "$(find . -maxdepth 1 -not -name '.git' -not -name '.' -not -name '..' 2>/dev/null)" ]; then
    git add .
    if ! git diff --staged --quiet 2>/dev/null || [ -n "$(git ls-files --others --exclude-standard)" ]; then
        git commit -m "Initial commit" || error "Failed to create commit"
        HAS_COMMITS=true
        success "Commit created"
    fi
fi

if [ "$HAS_COMMITS" = false ]; then
    git commit --allow-empty -m "Initial commit (empty repository)" || error "Failed to create empty commit"
    HAS_COMMITS=true
fi

CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "$DEFAULT_BRANCH")
if [ -z "$(git branch --show-current 2>/dev/null)" ]; then
    git checkout -b "$DEFAULT_BRANCH" 2>/dev/null || true
    CURRENT_BRANCH="$DEFAULT_BRANCH"
fi

info "Pushing to $SSH_REMOTE (branch: $CURRENT_BRANCH)..."
set +e
git -c credential.helper= push -u origin "$CURRENT_BRANCH" 2>&1
PUSH_ERROR=$?
set -e

if [ $PUSH_ERROR -eq 0 ]; then
    success "Successfully pushed to remote"
    success "Repository: https://github.com/$USER_REPO"
else
    error "Push failed. Try: git push -u origin $CURRENT_BRANCH"
fi
