#!/bin/bash
# apps/zed — install Zed editor
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "Zed"

if ! command -v brew &>/dev/null; then
    dotfiles_ui_error "Homebrew is required to install Zed."
    exit 1
fi

if [ -d "/Applications/Zed.app" ]; then
    dotfiles_ui_info "Zed already installed — checking for updates..."
    brew upgrade --cask zed 2>/dev/null && dotfiles_ui_success "Zed updated" || dotfiles_ui_info "Zed is up to date"
else
    dotfiles_ui_info "Installing Zed..."
    brew install --cask zed
    dotfiles_ui_success "Zed installed"
fi

dotfiles_ui_success "Zed setup complete"
