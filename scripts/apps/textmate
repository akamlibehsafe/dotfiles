#!/bin/bash
# apps/textmate — install TextMate
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "TextMate"

if ! command -v brew &>/dev/null; then
    dotfiles_ui_error "Homebrew is required to install TextMate."
    exit 1
fi

if [ -d "/Applications/TextMate.app" ]; then
    dotfiles_ui_info "TextMate already installed — checking for updates..."
    brew upgrade --cask textmate 2>/dev/null && dotfiles_ui_success "TextMate updated" || dotfiles_ui_info "TextMate is up to date"
else
    dotfiles_ui_info "Installing TextMate..."
    brew install --cask textmate
    dotfiles_ui_success "TextMate installed"
fi

dotfiles_ui_success "TextMate setup complete"
