#!/bin/bash
# apps/ghostty — install Ghostty and apply config
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"
REPO_ROOT="$(cd "${SCRIPTS_ROOT}/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

CONFIG_SRC="${REPO_ROOT}/config/ghostty/config"
CONFIG_DEST="${HOME}/.config/ghostty/config"

dotfiles_ui_section "Ghostty"

# ─── install ──────────────────────────────────────────────────────────────────

if [ -d "/Applications/Ghostty.app" ]; then
    dotfiles_ui_info "Ghostty already installed — checking for updates..."
    brew upgrade --cask ghostty 2>/dev/null && dotfiles_ui_success "Ghostty updated" || dotfiles_ui_info "Ghostty is up to date"
else
    if ! command -v brew &>/dev/null; then
        dotfiles_ui_error "Homebrew is required to install Ghostty."
        exit 1
    fi
    dotfiles_ui_info "Installing Ghostty..."
    if ! brew install --cask ghostty; then
        dotfiles_ui_error "Ghostty download failed."
        dotfiles_ui_info  "  Ghostty distributes only from release.files.ghostty.org — some corporate"
        dotfiles_ui_info  "  networks block this domain for non-browser traffic (TLS reset)."
        dotfiles_ui_info  "  Fix: open https://ghostty.org/download in a browser, download the macOS DMG,"
        dotfiles_ui_info  "  drag to /Applications, then re-run dotfiles_install — it will skip this step."
        exit 1
    fi
    dotfiles_ui_success "Ghostty installed"
fi

# ─── apply config ─────────────────────────────────────────────────────────────

if [ -f "$CONFIG_SRC" ]; then
    mkdir -p "$(dirname "$CONFIG_DEST")"
    if [ -f "$CONFIG_DEST" ]; then
        dotfiles_ui_info "Backing up existing Ghostty config..."
        cp "$CONFIG_DEST" "${CONFIG_DEST}.backup-$(date +%Y%m%d%H%M%S)"
    fi
    cp "$CONFIG_SRC" "$CONFIG_DEST"
    dotfiles_ui_success "Ghostty config applied → ${CONFIG_DEST}"
else
    dotfiles_ui_info "No config found at config/ghostty/config — skipping"
fi

dotfiles_ui_success "Ghostty setup complete"
