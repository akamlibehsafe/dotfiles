#!/bin/bash
# apps/sublime-text — install Sublime Text
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "Sublime Text"

if ! command -v brew &>/dev/null; then
    dotfiles_ui_error "Homebrew is required to install Sublime Text."
    exit 1
fi

if [ -d "/Applications/Sublime Text.app" ]; then
    dotfiles_ui_info "Sublime Text already installed — checking for updates..."
    brew upgrade --cask sublime-text 2>/dev/null && dotfiles_ui_success "Sublime Text updated" || dotfiles_ui_info "Sublime Text is up to date"
else
    dotfiles_ui_info "Installing Sublime Text..."
    brew install --cask sublime-text
    dotfiles_ui_success "Sublime Text installed"
fi

dotfiles_ui_success "Sublime Text setup complete"
