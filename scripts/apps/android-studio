#!/bin/bash
# apps/android-studio — install Android Studio via Homebrew cask
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "Android Studio"

if [ -d "/Applications/Android Studio.app" ]; then
    dotfiles_ui_info "Android Studio already installed — checking for updates..."
    brew upgrade --cask android-studio 2>/dev/null && dotfiles_ui_success "Android Studio updated" || dotfiles_ui_info "Android Studio is up to date"
else
    if ! command -v brew &>/dev/null; then
        dotfiles_ui_error "Homebrew is required to install Android Studio."
        exit 1
    fi
    dotfiles_ui_info "Installing Android Studio..."
    brew install --cask android-studio
    dotfiles_ui_success "Android Studio installed"
fi

dotfiles_ui_success "Android Studio setup complete"
