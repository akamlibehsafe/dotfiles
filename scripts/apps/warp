#!/bin/bash
# apps/warp — install Warp terminal
# No local config applied — Warp uses cloud sync via your Warp account.
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "Warp"

# ─── install ──────────────────────────────────────────────────────────────────

if [ -d "/Applications/Warp.app" ]; then
    dotfiles_ui_success "Warp already installed"
else
    if ! command -v brew &>/dev/null; then
        dotfiles_ui_error "Homebrew is required to install Warp."
        exit 1
    fi
    dotfiles_ui_info "Installing Warp..."
    brew install --cask warp
    dotfiles_ui_success "Warp installed"
fi

dotfiles_ui_info "Warp settings sync via your Warp account — log in after first launch."
dotfiles_ui_success "Warp setup complete"
