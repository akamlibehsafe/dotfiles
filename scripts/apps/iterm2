#!/bin/bash
# apps/iterm2 — install iTerm2 and apply bundled profile
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"
REPO_ROOT="$(cd "${SCRIPTS_ROOT}/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

PROFILE_SRC="${REPO_ROOT}/config/iterm2/iTerm2 State.itermexport"

dotfiles_ui_section "iTerm2"

# ─── install ──────────────────────────────────────────────────────────────────

if [ -d "/Applications/iTerm.app" ]; then
    _ver=$(/usr/libexec/PlistBuddy -c "Print:CFBundleShortVersionString" \
        /Applications/iTerm.app/Contents/Info.plist 2>/dev/null || echo "unknown")
    dotfiles_ui_info "iTerm2 already installed (version ${_ver}) — checking for updates..."
    brew upgrade --cask iterm2 2>/dev/null && dotfiles_ui_success "iTerm2 updated" || dotfiles_ui_info "iTerm2 is up to date"
else
    if ! command -v brew &>/dev/null; then
        dotfiles_ui_error "Homebrew is required to install iTerm2."
        exit 1
    fi
    dotfiles_ui_info "Installing iTerm2..."
    brew install --cask iterm2
    dotfiles_ui_success "iTerm2 installed"
fi

# ─── apply profile ────────────────────────────────────────────────────────────

if [ -f "$PROFILE_SRC" ]; then
    dotfiles_ui_info "Applying iTerm2 profile from config/iterm2/..."
    dotfiles_ui_info "Opening profile in iTerm2 — confirm the import in the app dialog."
    open -a iTerm "$PROFILE_SRC" 2>/dev/null || open "$PROFILE_SRC" 2>/dev/null || \
        dotfiles_ui_info "Could not open iTerm2 automatically. Import manually:"
    echo "  $PROFILE_SRC"
    dotfiles_ui_success "iTerm2 profile import initiated"
else
    dotfiles_ui_info "No bundled profile found at config/iterm2/ — skipping profile import"
fi

dotfiles_ui_success "iTerm2 setup complete"
