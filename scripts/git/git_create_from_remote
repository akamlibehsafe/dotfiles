#!/bin/bash

# git_create_from_remote
# Clones an existing GitHub repository via SSH alias.

set -e

_gitscripts_self="${BASH_SOURCE[0]}"
while [ -L "$_gitscripts_self" ]; do
    _d="$(cd "$(dirname "$_gitscripts_self")" && pwd)"
    _gitscripts_self="$(readlink "$_gitscripts_self")"
    [[ "$_gitscripts_self" != /* ]] && _gitscripts_self="$_d/$_gitscripts_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_gitscripts_self")" && pwd -P)"
SCRIPTS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
# shellcheck source=lib/init.sh
source "${SCRIPTS_ROOT}/lib/init.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

error() { echo -e "${RED}Error: $1${NC}" >&2; exit 1; }
success() { echo -e "${GREEN}$1${NC}"; }
info() { echo -e "${YELLOW}$1${NC}"; }

if [ $# -ne 1 ]; then
    error "Usage: git_create_from_remote <user/repo>\nExample: git_create_from_remote akamlibehsafe/myproject"
fi

USER_REPO="$1"
if [[ ! "$USER_REPO" =~ ^[^/]+/[^/]+$ ]]; then
    error "Invalid format. Expected: user/repo"
fi

USERNAME=$(echo "$USER_REPO" | cut -d'/' -f1)
REPO_NAME=$(echo "$USER_REPO" | cut -d'/' -f2)

if ! gitscripts_is_known_account "$USERNAME"; then
    error "Unknown username: $USERNAME\nSupported: $(gitscripts_supported_accounts_list)"
fi

CLONE_URL=$(gitscripts_remote_ssh_url "$USERNAME" "$REPO_NAME")

info "Cloning: $USER_REPO"
info "SSH URL: $CLONE_URL"

if ! command -v git &>/dev/null; then
    error "Git is not installed. Run setup_install first."
fi

HAS_LFS=false
if command -v git-lfs &>/dev/null || git lfs version &>/dev/null 2>&1; then
    HAS_LFS=true
    info "Git LFS is installed"
fi

if [ -d "$REPO_NAME" ]; then
    error "Directory '$REPO_NAME' already exists."
fi

info "Cloning from GitHub..."
set +e
git -c credential.helper= clone "$CLONE_URL" 2>&1
CLONE_ERROR=$?
set -e

if [ $CLONE_ERROR -ne 0 ]; then
    error "Clone failed.\nVerify repo exists, SSH keys, and: ssh -T git@$(gitscripts_account_ssh_host "$USERNAME")"
fi

success "Repository cloned successfully"

if [ -d "$REPO_NAME" ]; then
    cd "$REPO_NAME"
    CLONED_DIR=$(pwd -P)

    if [[ "$CLONED_DIR" =~ ^/tmp|^/private/tmp|^/var/tmp ]]; then
        SAFE_DIRS=$(git config --global --get-all safe.directory 2>/dev/null || echo "")
        if [ -z "$SAFE_DIRS" ] || ! echo "$SAFE_DIRS" | grep -Fxq "$CLONED_DIR"; then
            git config --global --add safe.directory "$CLONED_DIR"
        fi
    fi

    if [ "$HAS_LFS" = true ]; then
        if [ -f .gitattributes ] || git lfs ls-files &>/dev/null; then
            info "Pulling Git LFS files..."
            git lfs install --local 2>/dev/null || true
            git lfs pull 2>&1 | head -20 || true
        fi
    fi

    info "Repository information:"
    echo "  Remote URL: $(git remote get-url origin)"
    echo "  Current branch: $(git branch --show-current)"
    echo "  Commit email: $(git config user.email)"
    success "Ready at: $CLONED_DIR"
else
    error "Clone directory was not created."
fi
