#!/bin/bash
# setup_check — read-only scan of PATs, Keychain credentials, git identity, and remotes
# Run anytime to see the state of your environment.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd -P)"
SCRIPTS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

ACTIONS=()
PAT_OK=0; KEYCHAIN_OK=0; INCLUDE_OK=0
PAT_TOTAL=${#DOTFILES_ACCOUNTS[@]}
HTTPS_REMOTES=0; SSH_REMOTES=0; REPO_COUNT=0

dotfiles_ui_section "dotfiles setup_check (read-only)"

echo "GitHub root : ${DOTFILES_GITHUB_ROOT}"
echo "Accounts    : $(dotfiles_accounts_list)"
echo ""

# ─── PATs ─────────────────────────────────────────────────────────────────────

dotfiles_ui_section "Personal Access Tokens"

for user in "${DOTFILES_ACCOUNTS[@]}"; do
    pat_var="$(dotfiles_account_pat_var "$user")"
    # Prefer env var, fall back to dotfiles.conf value
    pat="$(dotfiles_account_pat_resolved "$user" || true)"
    if [ -n "$pat" ]; then
        export "${pat_var}=${pat}"
    fi
    status="$(dotfiles_verify_pat_api "$pat_var" "$user" || true)"
    case "$status" in
        ok)
            dotfiles_ui_success "  ${pat_var}: valid (${user})"
            PAT_OK=$((PAT_OK + 1))
            ;;
        missing)
            dotfiles_ui_info "  ${pat_var}: not set"
            ACTIONS+=("setup_pats → configure PAT for ${user}")
            ;;
        wrong_user:*)
            dotfiles_ui_error "  ${pat_var}: wrong GitHub user (${status#wrong_user:})"
            ACTIONS+=("setup_pats --force → re-configure PAT for ${user}")
            ;;
        *)
            dotfiles_ui_error "  ${pat_var}: ${status}"
            ACTIONS+=("setup_pats → check PAT for ${user}")
            ;;
    esac
done

# ─── Keychain credentials ─────────────────────────────────────────────────────

dotfiles_ui_section "Keychain credentials"

for user in "${DOTFILES_ACCOUNTS[@]}"; do
    if dotfiles_check_keychain_credential "$user" 2>/dev/null; then
        dotfiles_ui_success "  ${user}: credential present in Keychain"
        KEYCHAIN_OK=$((KEYCHAIN_OK + 1))
    else
        dotfiles_ui_info "  ${user}: no Keychain credential"
        ACTIONS+=("setup_ssh --repair → store Keychain credential for ${user}")
    fi
done

# ─── Git identity ─────────────────────────────────────────────────────────────

dotfiles_ui_section "Git identity (includeIf)"

if [ -f "$HOME/.gitconfig" ]; then
    for user in "${DOTFILES_ACCOUNTS[@]}"; do
        gitdir="$(dotfiles_account_gitdir "$user")"
        inc="gitdir:${gitdir}"
        cfg="$HOME/.gitconfig-${user}"
        if grep -Fq "$inc" "$HOME/.gitconfig" 2>/dev/null && [ -f "$cfg" ]; then
            dotfiles_ui_success "  ${inc} → ${cfg}"
            INCLUDE_OK=$((INCLUDE_OK + 1))
        else
            dotfiles_ui_info "  ${inc}: not configured"
            ACTIONS+=("setup_ssh --repair → configure git identity for ${user}")
        fi
    done
else
    dotfiles_ui_info "  ~/.gitconfig not found"
    ACTIONS+=("setup_ssh --repair → create ~/.gitconfig")
fi

# ─── Git credential helper ────────────────────────────────────────────────────

dotfiles_ui_section "Git credential config"

helper="$(git config --global credential.helper 2>/dev/null || echo "")"
if [ "$helper" = "osxkeychain" ]; then
    dotfiles_ui_success "  credential.helper = osxkeychain"
else
    dotfiles_ui_info "  credential.helper = ${helper:-not set}"
    ACTIONS+=("setup_ssh --repair → set git credential.helper = osxkeychain")
fi

# ─── Remotes ──────────────────────────────────────────────────────────────────

dotfiles_ui_section "Remotes under ${DOTFILES_GITHUB_ROOT}"

if [ -d "$DOTFILES_GITHUB_ROOT" ]; then
    while IFS= read -r git_dir; do
        [ -z "$git_dir" ] && continue
        REPO_COUNT=$((REPO_COUNT + 1))
        repo_root="$(dirname "$git_dir")"
        origin="$(git -C "$repo_root" remote get-url origin 2>/dev/null || echo "")"
        [ -z "$origin" ] && continue
        if [[ "$origin" =~ ^https:// ]]; then
            HTTPS_REMOTES=$((HTTPS_REMOTES + 1))
        elif [[ "$origin" =~ ^git@ ]]; then
            SSH_REMOTES=$((SSH_REMOTES + 1))
            dotfiles_ui_info "  SSH remote (needs migration): ${repo_root}"
        fi
    done < <(find "$DOTFILES_GITHUB_ROOT" -mindepth 3 -maxdepth 4 -type d -name .git 2>/dev/null)

    echo ""
    echo "  Repos scanned  : ${REPO_COUNT}"
    echo "  HTTPS origins  : ${HTTPS_REMOTES}"
    echo "  SSH origins    : ${SSH_REMOTES}"
    [ "$SSH_REMOTES" -gt 0 ] && ACTIONS+=("setup_migrate --apply → convert legacy SSH remotes to HTTPS")
else
    dotfiles_ui_info "  ${DOTFILES_GITHUB_ROOT} does not exist yet"
fi

# ─── Summary ──────────────────────────────────────────────────────────────────

dotfiles_ui_section "Summary"

PROFILE="partial"
[ "$PAT_OK" -eq "$PAT_TOTAL" ] && [ "$KEYCHAIN_OK" -eq "$PAT_TOTAL" ] && \
    [ "$INCLUDE_OK" -eq "$PAT_TOTAL" ] && [ "$SSH_REMOTES" -eq 0 ] && PROFILE="configured"
[ "$PAT_OK" -eq 0 ] && [ "$KEYCHAIN_OK" -eq 0 ] && [ "$INCLUDE_OK" -eq 0 ] && PROFILE="greenfield"

echo "  Profile     : ${PROFILE}"
echo "  PATs OK     : ${PAT_OK}/${PAT_TOTAL}"
echo "  Keychain OK : ${KEYCHAIN_OK}/${PAT_TOTAL}"
echo "  Identity    : ${INCLUDE_OK}/${PAT_TOTAL}"

if [ ${#ACTIONS[@]} -gt 0 ]; then
    echo ""
    dotfiles_ui_info "Suggested actions:"
    printf '%s\n' "${ACTIONS[@]}" | sort -u | while IFS= read -r action; do
        echo "  • ${action}"
    done
else
    echo ""
    dotfiles_ui_success "Environment looks fully configured."
fi

echo ""
exit 0
