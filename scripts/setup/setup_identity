#!/bin/bash
# setup_identity — git identity (includeIf) and Keychain credential setup
# Configures per-account git identity and stores PATs in the macOS Keychain.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd -P)"
SCRIPTS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

DRY_RUN=false
MODE="repair"

usage() {
    echo "Usage: setup_identity [--dry-run] [--new-mac | --repair]"
    echo ""
    echo "  Configure git identity (includeIf) and store PATs in macOS Keychain."
    echo ""
    echo "  --dry-run   Show planned changes only, make no changes"
    echo "  --new-mac   Full setup (default for fresh Mac)"
    echo "  --repair    Add only what is missing"
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=true; shift ;;
        --new-mac) MODE="new-mac"; shift ;;
        --repair)  MODE="repair"; shift ;;
        -h|--help) usage ;;
        *) dotfiles_usage_error "Unknown option: $1" "setup_identity [--dry-run] [--new-mac | --repair]" ;;
    esac
done

log_action() {
    if [ "$DRY_RUN" = true ]; then
        dotfiles_ui_info "[dry-run] $*"
    else
        dotfiles_ui_success "$*"
    fi
}

# ─── Git identity (includeIf) ─────────────────────────────────────────────────

ensure_gitconfig_include() {
    local user="$1"
    local gitdir inc cfg global email git_name
    gitdir="$(dotfiles_account_gitdir "$user")"
    inc="gitdir:${gitdir}"
    cfg="$HOME/.gitconfig-${user}"
    global="$HOME/.gitconfig"
    email="$(dotfiles_account_email "$user")"
    git_name="$(dotfiles_account_git_name "$user")"

    log_action "  Ensure includeIf ${inc}"
    [ "$DRY_RUN" = true ] && return 0

    # Create base ~/.gitconfig if missing
    if [ ! -f "$global" ]; then
        cat >"$global" <<'EOF'
[init]
    defaultBranch = main
[credential]
    helper = osxkeychain
EOF
    fi

    # Add includeIf block if missing
    if ! grep -Fq "$inc" "$global" 2>/dev/null; then
        {
            echo ""
            echo "[includeIf \"${inc}\"]"
            echo "    path = ~/.gitconfig-${user}"
        } >>"$global"
    fi

    # Write per-account gitconfig
    cat >"$cfg" <<EOF
[user]
    name = ${git_name}
    email = ${email}
EOF
}

# ─── Keychain credential storage ──────────────────────────────────────────────

ensure_keychain_credential() {
    local user="$1"
    local pat

    pat="$(dotfiles_account_pat_resolved "$user" || true)"
    if [ -z "$pat" ]; then
        dotfiles_ui_info "  No PAT for ${user} — skipping Keychain storage"
        return 0
    fi

    if [ "$MODE" = "repair" ] && dotfiles_check_keychain_credential "$user" 2>/dev/null; then
        log_action "  Keychain credential already present for ${user}"
        return 0
    fi

    log_action "  Store Keychain credential for ${user}"
    [ "$DRY_RUN" = true ] && return 0

    if dotfiles_store_keychain_credential "$user" "$pat"; then
        dotfiles_ui_success "  Keychain: stored credential for ${user}"
    else
        dotfiles_ui_info "  Keychain: could not store credential for ${user} (store manually via setup_pats)"
    fi
}

# ─── Git credential helper ────────────────────────────────────────────────────

ensure_git_credential_config() {
    log_action "  Configure git credential.helper = osxkeychain"
    [ "$DRY_RUN" = true ] && return 0

    git config --global credential.helper osxkeychain 2>/dev/null || \
        dotfiles_ui_info "  Could not set credential.helper (set manually: git config --global credential.helper osxkeychain)"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

dotfiles_ui_section "setup_identity (mode=${MODE}, dry_run=${DRY_RUN})"

ensure_git_credential_config

for user in "${DOTFILES_ACCOUNTS[@]}"; do
    dotfiles_ui_prompt "--- ${user} ---"
    ensure_gitconfig_include "$user"
    ensure_keychain_credential "$user"
    echo ""
done

# ─── Repair: rescan existing repos and rewrite [user] in .git/config ─────────

if [ "$MODE" = "repair" ] || [ "$MODE" = "new-mac" ]; then
    dotfiles_ui_section "Updating .git/config identity in existing repos"

    for user in "${DOTFILES_ACCOUNTS[@]}"; do
        user_dir="${DOTFILES_GITHUB_ROOT}/${user}"
        [ -d "$user_dir" ] || continue

        git_name="$(dotfiles_account_git_name "$user")"
        git_email="$(dotfiles_account_email "$user")"
        repaired=0

        while IFS= read -r git_dir; do
            [ -z "$git_dir" ] && continue
            repo_root="$(dirname "$git_dir")"
            log_action "  ${repo_root}"
            [ "$DRY_RUN" = true ] && continue
            git config --local -C "$repo_root" user.name  "$git_name"  2>/dev/null || true
            git config --local -C "$repo_root" user.email "$git_email" 2>/dev/null || true
            repaired=$((repaired + 1))
        done < <(find "$user_dir" -mindepth 2 -maxdepth 3 -type d -name .git 2>/dev/null)

        [ "$DRY_RUN" = false ] && dotfiles_ui_success "  ${user}: updated ${repaired} repo(s)"
    done
fi

dotfiles_ui_section "Done"
if [ "$DRY_RUN" = true ]; then
    echo "Re-run without --dry-run to apply changes."
else
    echo "Run setup_check to verify the full environment."
fi
