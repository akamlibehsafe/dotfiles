#!/bin/bash
# dotfiles_install — full macOS development environment bootstrap
# Run once on a fresh Mac. When it exits 0, the environment is fully ready.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
REPO_ROOT="$(cd "$(dirname "$_self")" && pwd -P)"
SCRIPTS_ROOT="${REPO_ROOT}/scripts"

# ─── macOS check ──────────────────────────────────────────────────────────────

[[ "$OSTYPE" == "darwin"* ]] || {
    echo "Error: dotfiles_install is for macOS only. Detected: $OSTYPE" >&2
    exit 1
}

# ─── dotfiles.conf must exist before we source lib ────────────────────────────

if [ ! -f "${REPO_ROOT}/dotfiles.conf" ]; then
    cat >&2 <<EOF

Error: dotfiles.conf not found.

Copy the template and fill in your details before running dotfiles_install:
  cp dotfiles.conf.example dotfiles.conf

See dotfiles.conf.example for the required format.
EOF
    exit 1
fi

export DOTFILES_CONF="${REPO_ROOT}/dotfiles.conf"
source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

# ─── helpers ──────────────────────────────────────────────────────────────────

SHELL_CONFIG="$(dotfiles_shell_config)"
SETUP_LOG="${REPO_ROOT}/.dotfiles_install.log"

phase_ok()   { dotfiles_ui_success "  ✓ $1"; }
phase_skip() { dotfiles_ui_info    "  - $1 (skipped)"; }
phase_fail() { dotfiles_ui_error   "  ✗ $1"; }

confirm() {
    dotfiles_ui_prompt "$1 (Y/n)"
    local ans; read -r ans
    [[ ! "$ans" =~ ^[Nn]$ ]]
}

run_phase() {
    local name="$1"; shift
    dotfiles_ui_section "$name"
    "$@"
}

brew_install() {
    local pkg="$1"
    if brew list "$pkg" &>/dev/null 2>&1; then
        dotfiles_ui_info "  ${pkg}: already installed"
    else
        dotfiles_ui_info "  Installing ${pkg}..."
        brew install "$pkg"
        dotfiles_ui_success "  ${pkg}: installed"
    fi
}

brew_cask_install() {
    local pkg="$1" app_path="$2"
    if [ -d "$app_path" ]; then
        dotfiles_ui_info "  ${pkg}: already installed"
    else
        dotfiles_ui_info "  Installing ${pkg}..."
        brew install --cask "$pkg"
        dotfiles_ui_success "  ${pkg}: installed"
    fi
}

# ─── Pre-flight: detect existing state ────────────────────────────────────────
# Sets STATE_* flags used by each phase to skip work already done.

dotfiles_ui_section "Checking current state..."

STATE_HOMEBREW=false
STATE_CORE_TOOLS=false
STATE_GITHUB_ROOT=false
STATE_PATS=false
STATE_IDENTITY=false
STATE_SHELL=false
STATE_SYMLINKS=false

# Homebrew
command -v brew &>/dev/null && STATE_HOMEBREW=true

# Core tools (all must be present)
if command -v git &>/dev/null && command -v gh &>/dev/null && \
   command -v jq &>/dev/null && command -v python3 &>/dev/null && \
   command -v node &>/dev/null; then
    STATE_CORE_TOOLS=true
fi

# GitHub root
[ -d "$DOTFILES_GITHUB_ROOT" ] && STATE_GITHUB_ROOT=true

# PATs — true only if GH_TOKEN_* exports are already present in shell config
_pat_ok=true
for _u in "${DOTFILES_ACCOUNTS[@]}"; do
    _pv="$(dotfiles_account_pat_var "$_u")"
    grep -q "${_pv}=" "$SHELL_CONFIG" 2>/dev/null || { _pat_ok=false; break; }
done
$_pat_ok && STATE_PATS=true
unset _u _pv _pat_ok

# Identity — includeIf blocks present and Keychain credentials stored
_id_ok=true
for _u in "${DOTFILES_ACCOUNTS[@]}"; do
    _gitdir="$(dotfiles_account_gitdir "$_u")"
    _inc="gitdir:${_gitdir}"
    _cfg="$HOME/.gitconfig-${_u}"
    if ! grep -Fq "$_inc" "$HOME/.gitconfig" 2>/dev/null || [ ! -f "$_cfg" ]; then
        _id_ok=false; break
    fi
    dotfiles_check_keychain_credential "$_u" 2>/dev/null || { _id_ok=false; break; }
done
$_id_ok && STATE_IDENTITY=true
unset _u _gitdir _inc _cfg _id_ok

# Shell — Oh My Zsh + p10k present
[ -d "$HOME/.oh-my-zsh" ] && [ -f "$HOME/.p10k.zsh" ] && STATE_SHELL=true

# Symlinks — all repo commands in ~/bin
_sym_ok=true
for _cmd in repo_init repo_clone repo_sync; do
    [ -f "$HOME/bin/$_cmd" ] || { _sym_ok=false; break; }
done
# Also check lib files are present
[ -d "$HOME/bin/lib" ] || _sym_ok=false
$_sym_ok && STATE_SYMLINKS=true
unset _cmd _sym_ok

echo "  homebrew    : $STATE_HOMEBREW"
echo "  core tools  : $STATE_CORE_TOOLS"
echo "  github root : $STATE_GITHUB_ROOT"
echo "  PATs        : $STATE_PATS"
echo "  identity    : $STATE_IDENTITY"
echo "  shell       : $STATE_SHELL"
echo "  symlinks    : $STATE_SYMLINKS"
echo ""

# ─── Pre-flight: legacy SSH cleanup ───────────────────────────────────────────
# Detect and offer to remove SSH artifacts left by older installs (pre-v0.6.0).

_legacy_ssh_keys=false
_legacy_ssh_config=false

[ -d "$HOME/.ssh/dotfiles" ] && _legacy_ssh_keys=true

if [ -f "$HOME/.ssh/config" ]; then
    grep -qE "dotfiles-managed|gitscripts-managed" "$HOME/.ssh/config" 2>/dev/null && \
        _legacy_ssh_config=true
fi

if [ "$_legacy_ssh_keys" = true ] || [ "$_legacy_ssh_config" = true ]; then
    dotfiles_ui_section "Legacy SSH cleanup"
    dotfiles_ui_info "  Detected SSH artifacts from a previous install:"
    [ "$_legacy_ssh_keys"   = true ] && dotfiles_ui_info "    ~/.ssh/dotfiles/ (SSH key files)"
    [ "$_legacy_ssh_config" = true ] && dotfiles_ui_info "    ~/.ssh/config (dotfiles-managed host blocks)"
    echo ""
    dotfiles_ui_info "  These are no longer used — auth is now HTTPS+PAT+Keychain."
    if confirm "Remove legacy SSH artifacts now?"; then
        if [ "$_legacy_ssh_keys" = true ]; then
            rm -rf "$HOME/.ssh/dotfiles"
            dotfiles_ui_success "  Removed ~/.ssh/dotfiles/"
        fi
        if [ "$_legacy_ssh_config" = true ]; then
            for _u in "${DOTFILES_ACCOUNTS[@]}"; do
                _host="github-${_u}"
                for _prefix in "dotfiles-managed" "gitscripts-managed"; do
                    _begin="# ${_prefix}-begin ${_host}"
                    _end="# ${_prefix}-end ${_host}"
                    if grep -q "$_begin" "$HOME/.ssh/config" 2>/dev/null; then
                        sed -i '' "/${_begin}/,/${_end}/d" "$HOME/.ssh/config" 2>/dev/null || true
                        dotfiles_ui_success "  Removed SSH config block for ${_host}"
                    fi
                done
                if grep -q "^Host ${_host}$" "$HOME/.ssh/config" 2>/dev/null; then
                    sed -i '' "/^Host ${_host}$/,/^$/d" "$HOME/.ssh/config" 2>/dev/null || true
                    dotfiles_ui_success "  Removed unmarked SSH config block for ${_host}"
                fi
            done
            unset _u _host _prefix _begin _end
        fi
    else
        dotfiles_ui_info "  Skipped — you can remove them manually later."
    fi
fi
unset _legacy_ssh_keys _legacy_ssh_config

# ─── Phase 1: Validate dotfiles.conf ─────────────────────────────────────────

run_phase "Phase 1: Validate dotfiles.conf"

echo "  Accounts    : $(dotfiles_accounts_list)"
echo "  GitHub root : ${DOTFILES_GITHUB_ROOT}"
echo ""

CONF_ERRORS=0
for user in "${DOTFILES_ACCOUNTS[@]}"; do
    pat="$(dotfiles_account_pat "$user")"

    if [ -z "$pat" ]; then
        dotfiles_ui_error "  Missing 'pat' for account: ${user}"
        CONF_ERRORS=$((CONF_ERRORS + 1))
    fi
done

[ "$CONF_ERRORS" -gt 0 ] && {
    echo ""
    dotfiles_ui_error "Fix the errors in dotfiles.conf and re-run dotfiles_install."
    exit 1
}

phase_ok "dotfiles.conf looks valid"

# Copy dotfiles.conf and templates/ to XDG location so scripts in ~/bin/
# can find them regardless of where the installer was run from.
XDG_CONF_DIR="${HOME}/.config/dotfiles"
XDG_CONF="${XDG_CONF_DIR}/dotfiles.conf"
mkdir -p "$XDG_CONF_DIR"
cp "${DOTFILES_CONF}" "$XDG_CONF"
chmod 600 "$XDG_CONF"
dotfiles_ui_success "  Copied dotfiles.conf → ${XDG_CONF}"

if [ -d "${REPO_ROOT}/templates" ]; then
    cp -r "${REPO_ROOT}/templates" "${XDG_CONF_DIR}/templates"
    dotfiles_ui_success "  Copied templates/ → ${XDG_CONF_DIR}/templates/"
fi

# ─── Phase 2: Homebrew ───────────────────────────────────────────────────────

run_phase "Phase 2: Homebrew"

if [ "$STATE_HOMEBREW" = true ]; then
    dotfiles_ui_info "  Homebrew already installed — updating..."
    brew update || dotfiles_ui_info "  Update skipped"
    phase_ok "Homebrew $(brew --version | head -n1)"
elif command -v brew &>/dev/null; then
    dotfiles_ui_info "  Homebrew already installed — updating..."
    brew update || dotfiles_ui_info "  Update skipped (may need manual intervention)"
else
    dotfiles_ui_info "  Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Add to PATH for Apple Silicon or Intel
    for brew_path in "/opt/homebrew/bin/brew" "/usr/local/bin/brew"; do
        if [ -f "$brew_path" ]; then
            eval "$("$brew_path" shellenv)"
            break
        fi
    done
fi

command -v brew &>/dev/null || {
    dotfiles_ui_error "Homebrew installed but 'brew' not found in PATH."
    dotfiles_ui_info  "Add Homebrew to PATH manually then re-run."
    exit 1
}

phase_ok "Homebrew $(brew --version | head -n1)"

# ─── Phase 3: Core tools ─────────────────────────────────────────────────────

run_phase "Phase 3: Core tools"

if [ "$STATE_CORE_TOOLS" = true ]; then
    phase_ok "Core tools already installed"
else

for pkg in git git-lfs gh jq python node; do
    brew_install "$pkg"
done

# Initialise git-lfs globally
git lfs install --system --skip-repo 2>/dev/null || git lfs install --skip-repo || true

phase_ok "Core tools ready"
fi

# ─── Phase 4: GitHub root directory ──────────────────────────────────────────

run_phase "Phase 4: GitHub root directory"

if [ "$STATE_GITHUB_ROOT" = true ]; then
    phase_ok "GitHub root already exists: ${DOTFILES_GITHUB_ROOT}"
else
    mkdir -p "$DOTFILES_GITHUB_ROOT"
    phase_ok "Created: ${DOTFILES_GITHUB_ROOT}"
fi

# ─── Phase 5: Auth setup (PATs + Keychain + git identity) ────────────────────

run_phase "Phase 5: Auth setup"

if [ "$STATE_PATS" = true ] && [ "$STATE_IDENTITY" = true ]; then
    phase_ok "PATs, Keychain credentials, and git identity already configured"
else

# Export PATs from dotfiles.conf into environment and shell config
dotfiles_ui_info "  Writing PAT exports to ${SHELL_CONFIG}..."
dotfiles_remove_lines_matching "$SHELL_CONFIG" "GH_TOKEN_"
dotfiles_remove_lines_matching "$SHELL_CONFIG" "# dotfiles PAT"

for user in "${DOTFILES_ACCOUNTS[@]}"; do
    pat="$(dotfiles_account_pat "$user")"
    pat_var="$(dotfiles_account_pat_var "$user")"
    export "${pat_var}=${pat}"
    {
        echo ""
        echo "# dotfiles PAT (${user})"
        echo "export ${pat_var}=\"${pat}\""
    } >>"$SHELL_CONFIG"
    dotfiles_ui_success "  Exported: ${pat_var}"
done

# Configure git credential helper and store PATs in macOS Keychain
dotfiles_ui_info "  Configuring git credential helper..."
git config --global credential.helper osxkeychain 2>/dev/null || \
    dotfiles_ui_info "  Warning: could not set credential.helper"

dotfiles_ui_info "  Storing credentials in macOS Keychain..."
for user in "${DOTFILES_ACCOUNTS[@]}"; do
    pat="$(dotfiles_account_pat "$user")"
    if dotfiles_store_keychain_credential "$user" "$pat"; then
        dotfiles_ui_success "  Keychain: stored credential for ${user}"
    else
        dotfiles_ui_info "  Keychain: could not store credential for ${user}"
    fi
done

# Set up git identity (includeIf per account folder)
dotfiles_ui_info "  Running git identity setup..."
bash "${SCRIPTS_ROOT}/setup/setup_identity" --new-mac

phase_ok "Auth configured"
fi

# ─── Phase 6: Shell (Zsh, Oh My Zsh, p10k) ───────────────────────────────────

run_phase "Phase 6: Shell"

if [ "$STATE_SHELL" = true ]; then
    phase_ok "Shell already configured"
else

# Install Zsh
brew_install zsh

# Set Zsh as default shell if not already
if [ "$SHELL" != "$(which zsh)" ]; then
    dotfiles_ui_info "  Setting Zsh as default shell..."
    ZSH_PATH="$(which zsh)"
    grep -Fxq "$ZSH_PATH" /etc/shells || sudo sh -c "echo ${ZSH_PATH} >> /etc/shells"
    chsh -s "$ZSH_PATH"
    dotfiles_ui_success "  Default shell set to Zsh"
fi

# Install Oh My Zsh if missing
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    dotfiles_ui_info "  Installing Oh My Zsh..."
    RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c \
        "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    dotfiles_ui_success "  Oh My Zsh installed"
else
    dotfiles_ui_info "  Oh My Zsh already installed"
fi

# Install Powerlevel10k theme
P10K_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k"
if [ ! -d "$P10K_DIR" ]; then
    dotfiles_ui_info "  Installing Powerlevel10k..."
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$P10K_DIR"
    dotfiles_ui_success "  Powerlevel10k installed"
else
    dotfiles_ui_info "  Powerlevel10k already installed"
fi

# Install Zsh plugins
PLUGINS_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
for plugin_repo in \
    "zsh-users/zsh-autosuggestions" \
    "zsh-users/zsh-syntax-highlighting"; do
    plugin_name="${plugin_repo#*/}"
    plugin_dir="${PLUGINS_DIR}/${plugin_name}"
    if [ ! -d "$plugin_dir" ]; then
        dotfiles_ui_info "  Installing ${plugin_name}..."
        git clone --depth=1 "https://github.com/${plugin_repo}.git" "$plugin_dir"
        dotfiles_ui_success "  ${plugin_name} installed"
    else
        dotfiles_ui_info "  ${plugin_name} already installed"
    fi
done

# Apply zshrc template (merge — only add if not already present)
dotfiles_ui_info "  Applying zshrc template..."
ZSHRC_TEMPLATE="${REPO_ROOT}/config/zshrc"
if [ -f "$ZSHRC_TEMPLATE" ]; then
    # Write a fresh .zshrc if it doesn't exist yet
    if [ ! -f "$HOME/.zshrc" ]; then
        cp "$ZSHRC_TEMPLATE" "$HOME/.zshrc"
        dotfiles_ui_success "  Created ~/.zshrc from template"
    else
        # Append template only if Oh My Zsh block not already present
        if ! grep -q 'oh-my-zsh.sh' "$HOME/.zshrc" 2>/dev/null; then
            {
                echo ""
                echo "# dotfiles shell config"
                cat "$ZSHRC_TEMPLATE"
            } >>"$HOME/.zshrc"
            dotfiles_ui_success "  Appended zshrc template to ~/.zshrc"
        else
            dotfiles_ui_info "  Oh My Zsh already configured in ~/.zshrc"
        fi
    fi
fi

# Apply p10k config (always overwrite — this is your config)
P10K_CONFIG="${REPO_ROOT}/config/p10k.zsh"
if [ -f "$P10K_CONFIG" ]; then
    cp "$P10K_CONFIG" "$HOME/.p10k.zsh"
    dotfiles_ui_success "  Applied ~/.p10k.zsh from config/p10k.zsh"
fi

# Apply gitconfig base (only if not already present — identity setup may have created it)
GITCONFIG_TEMPLATE="${REPO_ROOT}/config/gitconfig"
if [ -f "$GITCONFIG_TEMPLATE" ] && [ ! -f "$HOME/.gitconfig" ]; then
    cp "$GITCONFIG_TEMPLATE" "$HOME/.gitconfig"
    dotfiles_ui_success "  Created ~/.gitconfig from template"
fi

phase_ok "Shell configured"
fi

# ─── Phase 7: Apps ───────────────────────────────────────────────────────────

run_phase "Phase 7: Apps"

app_is_installed() {
    case "$1" in
        iterm2)       [ -d "/Applications/iTerm.app" ] ;;
        ghostty)      [ -d "/Applications/Ghostty.app" ] ;;
        warp)         [ -d "/Applications/Warp.app" ] ;;
        cursor)       [ -d "/Applications/Cursor.app" ] ;;
        claude)       [ -d "/Applications/Claude.app" ] ;;
        claude-cli)      command -v claude &>/dev/null ;;
        android-studio)  [ -d "/Applications/Android Studio.app" ] ;;
        vscode)          [ -d "/Applications/Visual Studio Code.app" ] ;;
        openspec)        command -v openspec &>/dev/null ;;
        typora)       [ -d "/Applications/Typora.app" ] ;;
        arc)          [ -d "/Applications/Arc.app" ] ;;
        zed)          [ -d "/Applications/Zed.app" ] ;;
        sublime-text) [ -d "/Applications/Sublime Text.app" ] ;;
        textmate)     [ -d "/Applications/TextMate.app" ] ;;
    esac
}

for app in iterm2 ghostty warp cursor vscode claude claude-cli android-studio openspec typora arc zed sublime-text textmate; do
    app_script="${SCRIPTS_ROOT}/apps/${app}"
    if [ -f "$app_script" ]; then
        dotfiles_ui_section "${app}"
        if app_is_installed "$app"; then
            dotfiles_ui_success "  ${app} already installed — running config only"
            bash "$app_script"
        elif confirm "Install ${app}?"; then
            bash "$app_script"
        else
            phase_skip "$app"
        fi
    fi
done

phase_ok "Apps done"

# ─── Phase 8: Bulk clone ─────────────────────────────────────────────────────

run_phase "Phase 8: Bulk clone"

command -v jq &>/dev/null || {
    dotfiles_ui_info "  jq not found — skipping bulk clone"
}

if command -v jq &>/dev/null && confirm "Clone all repos from your GitHub accounts?"; then
    for user in "${DOTFILES_ACCOUNTS[@]}"; do
        dotfiles_account_clone_enabled "$user" || {
            dotfiles_ui_info "  Skipping bulk clone for ${user} (clone no in dotfiles.conf)"
            continue
        }

        pat="$(dotfiles_account_pat_resolved "$user" || true)"
        [ -n "$pat" ] || {
            dotfiles_ui_info "  No PAT for ${user} — skipping"
            continue
        }

        USER_DIR="${DOTFILES_GITHUB_ROOT}/${user}"
        mkdir -p "$USER_DIR"
        dotfiles_ui_info "  Fetching repository list for ${user}..."

        page=1; per_page=100
        while true; do
            resp=$(curl -s -w "\n%{http_code}" \
                -H "Accept: application/vnd.github.v3+json" \
                -H "Authorization: token ${pat}" \
                "https://api.github.com/user/repos?per_page=${per_page}&page=${page}&type=all")
            code="$(echo "$resp" | tail -n1)"
            body="$(echo "$resp" | sed '$d')"

            [ "$code" = "200" ] || { dotfiles_ui_info "  API error (HTTP ${code}) for ${user}"; break; }

            count="$(echo "$body" | jq 'length' 2>/dev/null || echo 0)"
            [ "$count" -eq 0 ] && break

            while IFS='|' read -r repo_name _clone_url; do
                [ -z "$repo_name" ] && continue
                dest="${USER_DIR}/${repo_name}"
                if [ -d "$dest" ]; then
                    dotfiles_ui_info "  Already exists: ${user}/${repo_name}"
                else
                    clone_url="$(dotfiles_remote_https_url "$user" "$repo_name")"
                    dotfiles_ui_info "  Cloning ${user}/${repo_name}..."
                    set +e
                    git clone "$clone_url" "$dest" 2>&1 | tail -1
                    clone_status=$?
                    set -e
                    if [ "$clone_status" -eq 0 ]; then
                        dotfiles_ui_success "  ✓ ${user}/${repo_name}"
                    else
                        dotfiles_ui_info "  ✗ ${user}/${repo_name} (clone failed)"
                    fi
                fi
            done < <(echo "$body" | jq -r '.[] | "\(.name)|\(.clone_url)"' 2>/dev/null)

            [ "$count" -lt "$per_page" ] && break
            page=$((page + 1))
        done
        dotfiles_ui_success "  Bulk clone done for ${user}"
    done
else
    phase_skip "bulk clone"
fi

phase_ok "Clone phase done"

# ─── Phase 9: Copy scripts to ~/bin/ ────────────────────────────────────────

run_phase "Phase 9: Install scripts"

bash "${SCRIPTS_ROOT}/setup/update_scripts"
phase_ok "Scripts installed to ~/bin/"

# ─── Phase 10: Shell aliases ─────────────────────────────────────────────────

run_phase "Phase 10: Shell aliases"

if grep -q "# dotfiles aliases" "$HOME/.zshrc" 2>/dev/null; then
    dotfiles_ui_info "  Aliases already present in ~/.zshrc"
else
    {
        echo ""
        echo "# dotfiles aliases"
    } >>"$HOME/.zshrc"

    for alias_entry in "${DOTFILES_SHELL_ALIASES[@]}"; do
        alias_name="${alias_entry%%|*}"
        alias_path="${alias_entry#*|}"
        if [ "$alias_path" = "." ]; then
            echo "alias ${alias_name}=\"cd ${DOTFILES_GITHUB_ROOT}\"" >>"$HOME/.zshrc"
        else
            echo "alias ${alias_name}=\"cd ${DOTFILES_GITHUB_ROOT}/${alias_path}\"" >>"$HOME/.zshrc"
        fi
    done
    dotfiles_ui_success "  Aliases written to ~/.zshrc"
fi

phase_ok "Aliases done"

# ─── Phase 11: Final verification ─────────────────────────────────────────────

run_phase "Phase 11: Verification"

# Source the shell config to pick up PATH changes
export PATH="$HOME/bin:$PATH"

VERIFY_ERRORS=0
for cmd in repo_init repo_clone repo_sync; do
    if command -v "$cmd" &>/dev/null || [ -f "$HOME/bin/$cmd" ]; then
        dotfiles_ui_success "  ✓ ${cmd}"
    else
        dotfiles_ui_error "  ✗ ${cmd} not found in ~/bin/"
        VERIFY_ERRORS=$((VERIFY_ERRORS + 1))
    fi
done

[ "$VERIFY_ERRORS" -gt 0 ] && \
    dotfiles_ui_info "  Run: scripts/setup/update_scripts to fix missing commands"

phase_ok "Verification complete"

# ─── Phase 12: Dock ──────────────────────────────────────────────────────────

run_phase "Phase 12: Dock"

DOCK_APPS=(
    "/Applications/iTerm.app"
    "/Applications/Ghostty.app"
    "/Applications/Warp.app"
    "/Applications/Cursor.app"
    "/Applications/Visual Studio Code.app"
    "/Applications/Claude.app"
    "/Applications/Raycast.app"
    "/Applications/Typora.app"
    "/Applications/Arc.app"
    "/Applications/Android Studio.app"
    "/Applications/Zed.app"
    "/Applications/Sublime Text.app"
    "/Applications/TextMate.app"
)

if ! command -v dockutil &>/dev/null; then
    dotfiles_ui_info "  Installing dockutil..."
    brew install dockutil --quiet && dotfiles_ui_success "  dockutil installed" || \
        { dotfiles_ui_info "  Could not install dockutil — skipping Dock setup"; DOCK_APPS=(); }
fi

if command -v dockutil &>/dev/null; then
    for app_path in ${DOCK_APPS[@]+"${DOCK_APPS[@]}"}; do
        app_name="$(basename "$app_path" .app)"
        if [ -d "$app_path" ]; then
            if dockutil --find "$app_name" &>/dev/null 2>&1; then
                dotfiles_ui_info "  ${app_name} already in Dock"
            else
                dockutil --add "$app_path" --position end --no-restart &>/dev/null
                dotfiles_ui_success "  Added ${app_name} to Dock"
            fi
        else
            dotfiles_ui_info "  ${app_name} not installed — skipping Dock entry"
        fi
    done
    killall Dock 2>/dev/null || true
    dotfiles_ui_success "  Dock updated"
fi

phase_ok "Dock configured"

# ─── Phase 13: Terminal font ──────────────────────────────────────────────────

run_phase "Phase 13: Terminal font"

if fc-list 2>/dev/null | grep -qi "MesloLGS" || system_profiler SPFontsDataType 2>/dev/null | grep -qi "MesloLGS"; then
    dotfiles_ui_info "  MesloLGS NF found — skipping install"
else
    dotfiles_ui_info "  Installing MesloLGS NF font..."
    brew install --cask font-meslo-lg-nerd-font && dotfiles_ui_success "  MesloLGS NF installed" || \
        dotfiles_ui_info "  Could not install font — skipping Terminal font config"
fi

dotfiles_ui_info "  Configuring macOS Terminal to use MesloLGS NF..."
osascript <<'APPLESCRIPT' 2>/dev/null && dotfiles_ui_success "  Terminal font set to MesloLGS NF" || \
    dotfiles_ui_info "  Could not set Terminal font (Terminal may not be running)"
tell application "Terminal"
    set font name of default settings to "MesloLGS-NF-Regular"
    set font size of default settings to 13
    set font name of startup settings to "MesloLGS-NF-Regular"
    set font size of startup settings to 13
end tell
