#!/bin/bash
# apps/cursor — install Cursor editor
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "Cursor"

# ─── install ──────────────────────────────────────────────────────────────────

if [ -d "/Applications/Cursor.app" ]; then
    dotfiles_ui_info "Cursor already installed — checking for updates..."
    brew upgrade --cask cursor 2>/dev/null && dotfiles_ui_success "Cursor updated" || dotfiles_ui_info "Cursor is up to date"
else
    if ! command -v brew &>/dev/null; then
        dotfiles_ui_error "Homebrew is required to install Cursor."
        exit 1
    fi
    dotfiles_ui_info "Installing Cursor..."
    brew install --cask cursor
    dotfiles_ui_success "Cursor installed"
fi

dotfiles_ui_success "Cursor setup complete"
