#!/bin/bash
# apps/arc — install Arc browser
# Run standalone or called by dotfiles_install.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
    _d="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_d/$_self"
done
SCRIPTS_ROOT="$(cd "$(dirname "$_self")/.." && pwd -P)"

source "${SCRIPTS_ROOT}/lib/init.sh"
dotfiles_ui_colors

dotfiles_ui_section "Arc"

if ! command -v brew &>/dev/null; then
    dotfiles_ui_error "Homebrew is required to install Arc."
    exit 1
fi

if [ -d "/Applications/Arc.app" ]; then
    dotfiles_ui_info "Arc already installed — checking for updates..."
    brew upgrade --cask arc 2>/dev/null && dotfiles_ui_success "Arc updated" || dotfiles_ui_info "Arc is up to date"
else
    dotfiles_ui_info "Installing Arc..."
    brew install --cask arc
    dotfiles_ui_success "Arc installed"
fi

dotfiles_ui_success "Arc setup complete"
